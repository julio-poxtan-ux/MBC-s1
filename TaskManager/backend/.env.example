# ──────────────────────────────────────────────
# Bitácora Backend — Variables de entorno
# Copiá este archivo como .env y completá los valores
# NUNCA subas .env a git
# ──────────────────────────────────────────────

# Puerto del servidor Express
PORT=3000

# ── Cloud SQL ──────────────────────────────────
# Nombre de conexión: proyecto:región:instancia
# Lo encontrás en Cloud Console → SQL → tu instancia → "Connection name"
CLOUD_SQL_CONNECTION_NAME=mi-proyecto:us-central1:mi-instancia

# Credenciales de la base de datos
DB_USER=postgres
DB_PASSWORD=mi_contraseña_segura
DB_NAME=bitacora

# ── Desarrollo local (sin Cloud SQL Proxy) ─────
# Usá estas variables si querés conectarte directamente
# a un PostgreSQL local (para pruebas sin nube)
DB_HOST=127.0.0.1
DB_PORT=5432

# ── CORS ───────────────────────────────────────
# Origen del frontend. En producción poné la URL real.
# Para desarrollo local con Live Server:
FRONTEND_ORIGIN=http://127.0.0.1:5500

# ── Modo ───────────────────────────────────────
# "production" usa Cloud SQL Connector
# "development" usa conexión directa (DB_HOST/DB_PORT)
NODE_ENV=development
